{
  "properties": [
    {
      "name": "app.storage.minio.endpoint",
      "type": "java.lang.String",
      "description": "MinIO server endpoint used by the application."
    },
    {
      "name": "app.storage.minio.access-key",
      "type": "java.lang.String",
      "description": "MinIO access key."
    },
    {
      "name": "app.storage.minio.secret-key",
      "type": "java.lang.String",
      "description": "MinIO secret key."
    },
    {
      "name": "app.storage.minio.photo-bucket",
      "type": "java.lang.String",
      "description": "Bucket that stores researcher photos."
    },
    {
      "name": "app.storage.minio.pdf-bucket",
      "type": "java.lang.String",
      "description": "Bucket that stores publication PDFs."
    },
    {
      "name": "app.storage.minio.presign-expiry-seconds",
      "type": "java.lang.Integer",
      "description": "Lifetime in seconds of generated MinIO presigned download URLs."
    }
  ]
}