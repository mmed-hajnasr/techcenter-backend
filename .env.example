# PostgreSQL (used by docker compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=techcenter

# Backend datasource (used by Spring Boot / Hibernate)
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__NAME=techcenter
DATABASE__USERNAME=postgres
DATABASE__PASSWORD=postgres

DATABASE_URL=postgres://${DATABASE__USERNAME}:${DATABASE__PASSWORD}@localhost:${DATABASE__PORT}/${DATABASE__NAME}

# Optional Hibernate toggles
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_FORMAT_SQL=true

# Optional Redis/Jaeger ports
REDIS_PORT=6379
JAEGER_VERSION=2.10.0
JAEGER_LOG_LEVEL=info

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

